---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Logg inn" description="Logg inn for å få tilgang til eksklusive artikler.">
  <div class="login-page container">
    <div class="login-card">
      <div class="login-icon" aria-hidden="true">🔒</div>
      <h1 class="login-title" data-i18n="login.title">Logg inn</h1>
      <p class="login-desc" data-i18n="login.desc">
        Opprett en gratis konto for å få tilgang til eksklusive artikler.
      </p>
      <button id="google-signin" class="google-btn">
        <svg class="google-logo" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#4285F4" d="M23.745 12.27c0-.79-.07-1.54-.19-2.27h-11.36v4.51h6.5c-.29 1.48-1.14 2.73-2.4 3.58v3h3.86c2.26-2.09 3.56-5.17 3.56-8.82z"/>
          <path fill="#34A853" d="M12.195 24c3.24 0 5.95-1.08 7.93-2.91l-3.86-3c-1.08.72-2.45 1.16-4.07 1.16-3.13 0-5.78-2.11-6.73-4.96h-3.98v3.09C3.515 21.3 7.565 24 12.195 24z"/>
          <path fill="#FBBC05" d="M5.465 14.29c-.25-.72-.38-1.49-.38-2.29s.14-1.57.38-2.29V6.62h-3.98a11.86 11.86 0 000 10.76l3.98-3.09z"/>
          <path fill="#EA4335" d="M12.195 4.75c1.77 0 3.35.61 4.6 1.8l3.42-3.42C18.145 1.19 15.435 0 12.195 0c-4.63 0-8.68 2.7-10.71 6.62l3.98 3.09c.95-2.85 3.6-4.96 6.73-4.96z"/>
        </svg>
        <span data-i18n="login.google-btn">Logg inn med Google</span>
      </button>
      <p class="login-note" data-i18n="login.note">Innholdet er gratis — registrering gir tilgang.</p>
    </div>
  </div>
</BaseLayout>

<script>
  import { supabase } from '../lib/supabase';

  document.getElementById('google-signin')?.addEventListener('click', async () => {
    await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: { redirectTo: `${location.origin}/auth/callback` },
    });
  });
</script>

<style>
  .login-page {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 60vh;
    padding-block: var(--spacing-3xl);
  }

  .login-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-2xl) var(--spacing-xl);
    max-width: 400px;
    width: 100%;
    text-align: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  }

  .login-icon {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-md);
    display: block;
  }

  .login-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-heading);
    margin: 0 0 var(--spacing-sm);
  }

  .login-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-muted);
    margin: 0 0 var(--spacing-xl);
  }

  .google-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.5rem;
    background: #fff;
    border: 1.5px solid #dadce0;
    border-radius: 6px;
    font-family: var(--font-ui);
    font-size: 0.95rem;
    font-weight: 500;
    color: #3c4043;
    cursor: pointer;
    transition: background 0.15s, box-shadow 0.15s;
    width: 100%;
    justify-content: center;
  }

  .google-btn:hover {
    background: #f8f9fa;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
  }

  .google-logo { width: 20px; height: 20px; flex-shrink: 0; }

  .login-note {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--color-muted);
    margin: var(--spacing-lg) 0 0;
  }
</style>
