---
import { getCollection } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { articleSlug } from '../../utils/slug';
import researchContext from '../../data/research-context.json';

export async function getStaticPaths() {
  const entries = await getCollection('articles', (e) => !e.data.draft);
  return entries.map((entry) => ({
    params: { slug: articleSlug(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const allEntries = await getCollection('articles', (e) => !e.data.draft);

// Sorted descending by date for prev/next
const sortedAll = [...allEntries].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const currentIdx = sortedAll.findIndex((e) => e.id === entry.id);
const nextEntry = currentIdx > 0 ? sortedAll[currentIdx - 1] : null;        // newer
const prevEntry = currentIdx < sortedAll.length - 1 ? sortedAll[currentIdx + 1] : null; // older

// Related: prefer relatedSlugs, else same category
const otherEntries = allEntries.filter((e) => e.id !== entry.id);
let related = otherEntries.filter(
  (e) => entry.data.relatedSlugs?.includes(articleSlug(e.id))
);

if (related.length === 0) {
  related = otherEntries
    .filter((e) => e.data.category === entry.data.category)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
    .slice(0, 3);
}
const slug = articleSlug(entry.id);
const research = (researchContext as Record<string, { summary: string; lastVerified: string }>)[slug] ?? null;
---

<ArticleLayout entry={entry} related={related} prev={prevEntry} next={nextEntry} headings={headings} researchContext={research}>
  <Content />
</ArticleLayout>
