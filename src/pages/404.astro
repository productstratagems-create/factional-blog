---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Side ikke funnet"
  description="Siden du leter etter finnes ikke."
>
  <div class="error-page container">
    <p class="error-code">404</p>
    <h1 class="error-title">Side ikke funnet</h1>
    <p class="error-message">
      Siden du leter etter finnes ikke eller har blitt flyttet.
    </p>
    <a href="/" class="btn-home">Tilbake til forsiden</a>
  </div>
</BaseLayout>

<style>
  .error-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-block: var(--spacing-3xl);
    gap: var(--spacing-md);
  }

  .error-code {
    font-family: var(--font-display);
    font-size: 6rem;
    font-weight: 800;
    color: var(--color-teal);
    line-height: 1;
    margin: 0;
  }

  .error-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-heading);
  }

  .error-message {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--color-muted);
    max-width: 40ch;
  }

  .btn-home {
    display: inline-block;
    margin-top: var(--spacing-md);
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.7em 1.6em;
    background: var(--color-navy);
    color: #fff;
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: background 0.15s;
  }

  .btn-home:hover { background: var(--color-heading); }
</style>
