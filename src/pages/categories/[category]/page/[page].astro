---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ArticleGrid from '../../../../components/ArticleGrid.astro';
import ArticleTimeline from '../../../../components/ArticleTimeline.astro';
import ArticleControls from '../../../../components/ArticleControls.astro';
import Divider from '../../../../components/Divider.astro';
import { siteHref } from '../../../../utils/slug';

export async function getStaticPaths() {
  const PAGE_SIZE = 18;
  const allArticles = await getCollection('articles', (e) => !e.data.draft);
  const categories = [...new Set(allArticles.map((a) => a.data.category))];

  const paths: {
    params: { category: string; page: string };
    props: {
      articles: typeof allArticles;
      category: string;
      pageNum: number;
      totalPages: number;
      total: number;
    };
  }[] = [];

  for (const category of categories) {
    const catArticles = allArticles
      .filter((a) => a.data.category === category)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
    const totalPages = Math.ceil(catArticles.length / PAGE_SIZE);

    for (let pageNum = 2; pageNum <= totalPages; pageNum++) {
      paths.push({
        params: { category, page: String(pageNum) },
        props: {
          articles: catArticles.slice((pageNum - 1) * PAGE_SIZE, pageNum * PAGE_SIZE),
          category,
          pageNum,
          totalPages,
          total: catArticles.length,
          countNo: catArticles.filter(a => a.data.lang !== 'en').length,
          countEn: catArticles.filter(a => a.data.lang === 'en').length,
        },
      });
    }
  }

  return paths;
}

const { articles, category, pageNum, totalPages, total, countNo, countEn } = Astro.props;

const categoryLabels: Record<string, string> = {
  'luftvern':        'Luftvern',
  'missilforsvar':   'Missilforsvar',
  'missile-systems': 'Missilsystemer',
  'procurement':     'Anskaffelser',
  'anskaffelse':     'Anskaffelse',
  'policy':          'Forsvarspolitikk',
  'exercises':       'Øvelser',
  'history':         'Historie',
  'analyse':         'Analyse',
  'analysis':        'Analyse',
  'teknologi':       'Teknologi',
  'nato':            'NATO',
};

const label = categoryLabels[category] ?? category;
const prevHref = siteHref(pageNum === 2 ? `/categories/${category}` : `/categories/${category}/page/${pageNum - 1}`);
const nextHref = pageNum < totalPages ? siteHref(`/categories/${category}/page/${pageNum + 1}`) : null;
---

<BaseLayout
  title={`${label} — side ${pageNum} | Norsk Luftvern`}
  description={`Artikler om ${label.toLowerCase()} på Norsk Luftvern, side ${pageNum}.`}
>
  <div class="category-page">
    <div class="container">
      <header class="page-header">
        <p class="page-super">Kategori</p>
        <h1 class="page-title">{label}</h1>
        <p class="article-count" data-count-all={total} data-count-no={countNo} data-count-en={countEn}>
          <span id="page-count-num">{total}</span> <span data-i18n="cat.articles">artikler</span>
        </p>
      </header>

      <Divider spacing="md" />

      <ArticleControls totalCount={articles.length} />

      <div class="articles-wrapper">
        <ArticleGrid articles={articles} columns={3} id="article-grid" />
        <ArticleTimeline articles={articles} />
      </div>

      <nav class="pagination" aria-label="Sidenavigasjon">
        <a class="pagination-btn" href={prevHref}>← Forrige</a>
        <span class="pagination-info">Side {pageNum} av {totalPages}</span>
        {nextHref
          ? <a class="pagination-btn" href={nextHref}>Neste →</a>
          : <span class="pagination-btn pagination-btn--disabled">Neste →</span>
        }
      </nav>
    </div>
  </div>
</BaseLayout>

<style>
  .category-page { padding-bottom: var(--spacing-3xl); }

  .page-header {
    padding-block: var(--spacing-2xl) var(--spacing-xl);
  }

  .page-super {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-teal);
    margin-bottom: var(--spacing-sm);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-heading);
    line-height: 1;
    margin-bottom: var(--spacing-sm);
  }

  .article-count {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--color-muted);
    margin: 0;
  }

  .articles-wrapper { padding-block: var(--spacing-xl); }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-md);
    padding-block: var(--spacing-xl) var(--spacing-2xl);
  }

  .pagination-btn {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.5em 1.2em;
    border: 2px solid var(--color-navy);
    color: var(--color-navy);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  a.pagination-btn:hover {
    background: var(--color-navy);
    color: #fff;
  }

  .pagination-btn--disabled {
    opacity: 0.3;
    cursor: default;
    pointer-events: none;
  }

  .pagination-info {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-muted);
    white-space: nowrap;
  }
</style>

