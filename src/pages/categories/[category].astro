---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleGrid from '../../components/ArticleGrid.astro';
import ArticleTimeline from '../../components/ArticleTimeline.astro';
import ArticleControls from '../../components/ArticleControls.astro';
import Divider from '../../components/Divider.astro';
import { siteHref } from '../../utils/slug';

export async function getStaticPaths() {
  const PAGE_SIZE = 18;
  const allArticles = await getCollection('articles', (e) => !e.data.draft);
  const categories = [...new Set(allArticles.map((a) => a.data.category))];

  return categories.map((category) => {
    const catArticles = allArticles
      .filter((a) => a.data.category === category)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
    const totalPages = Math.ceil(catArticles.length / PAGE_SIZE);
    return {
      params: { category },
      props: {
        articles: catArticles.slice(0, PAGE_SIZE),
        category,
        total: catArticles.length,
        countNo: catArticles.filter(a => a.data.lang !== 'en').length,
        countEn: catArticles.filter(a => a.data.lang === 'en').length,
        totalPages,
      },
    };
  });
}

const { articles, category, total, countNo, countEn, totalPages } = Astro.props;

const categoryLabels: Record<string, string> = {
  'luftvern':        'Luftvern',
  'missilforsvar':   'Missilforsvar',
  'missile-systems': 'Missilsystemer',
  'procurement':     'Anskaffelser',
  'anskaffelse':     'Anskaffelse',
  'policy':          'Forsvarspolitikk',
  'exercises':       'Øvelser',
  'history':         'Historie',
  'analyse':         'Analyse',
  'analysis':        'Analyse',
  'teknologi':       'Teknologi',
  'nato':            'NATO',
};

const label = categoryLabels[category] ?? category;

const subCategoryMap: Record<string, { slug: string; label: string; i18nKey: string }[]> = {
  teknologi: [{ slug: 'directed-energy', label: 'Høyenergivåpen', i18nKey: 'cat.name.directed-energy' }],
};
const subCats = subCategoryMap[category] ?? [];

const parentCategoryMap: Record<string, { slug: string; label: string }> = {
  'directed-energy': { slug: 'teknologi', label: 'Teknologi' },
};
const parentCat = parentCategoryMap[category];
---

<BaseLayout
  title={label}
  description={`Alle artikler om ${label.toLowerCase()} på Norsk Luftvern.`}
>
  <div class="category-page">
    <div class="container">
      <header class="page-header">
        {parentCat && (
          <a href={siteHref(`/categories/${parentCat.slug}`)} class="parent-breadcrumb">
            ← <span data-i18n={`cat.name.${parentCat.slug}`}>{parentCat.label}</span>
          </a>
        )}
        <p class="page-super" data-i18n="cat.label">Kategori</p>
        <h1 class="page-title" data-i18n={`cat.name.${category}`}>{label}</h1>
        <p class="article-count" data-count-all={total} data-count-no={countNo} data-count-en={countEn}>
          <span id="page-count-num">{total}</span> <span data-i18n="cat.articles">artikler</span>
        </p>
      </header>

      {subCats.length > 0 && (
        <div class="subcategory-list">
          {subCats.map(sc => (
            <a href={siteHref(`/categories/${sc.slug}`)} class="subcategory-link" data-i18n={sc.i18nKey}>
              {sc.label}
            </a>
          ))}
        </div>
      )}

      <Divider spacing="md" />

      <ArticleControls totalCount={articles.length} />

      <div class="articles-wrapper">
        <ArticleGrid articles={articles} columns={3} id="article-grid" />
        <ArticleTimeline articles={articles} />
      </div>

      {totalPages > 1 && (
        <nav class="pagination" aria-label="Sidenavigasjon">
          <span class="pagination-btn pagination-btn--disabled" data-i18n="page.prev">← Forrige</span>
          <span class="pagination-info"><span data-i18n="page.page">Side</span> 1 <span data-i18n="page.of">av</span> {totalPages}</span>
          <a class="pagination-btn" href={siteHref(`/categories/${category}/page/2`)} data-i18n="page.next">Neste →</a>
        </nav>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .category-page { padding-bottom: var(--spacing-3xl); }

  .page-header {
    padding-block: var(--spacing-2xl) var(--spacing-xl);
  }

  .page-super {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-teal);
    margin-bottom: var(--spacing-sm);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-heading);
    line-height: 1;
    margin-bottom: var(--spacing-sm);
  }

  .article-count {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--color-muted);
    margin: 0;
  }

  .articles-wrapper { padding-block: var(--spacing-xl); }

  .parent-breadcrumb {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-teal);
    text-decoration: none;
    margin-bottom: var(--spacing-sm);
    transition: color 0.15s;
  }
  .parent-breadcrumb:hover { color: var(--color-navy); }

  .subcategory-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    padding-block: var(--spacing-md);
  }

  .subcategory-link {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3em 0.9em;
    border: 1.5px solid var(--color-teal);
    color: var(--color-teal);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .subcategory-link:hover {
    background: var(--color-teal);
    color: #fff;
  }

  /* ── Pagination ── */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-md);
    padding-block: var(--spacing-xl) var(--spacing-2xl);
  }

  .pagination-btn {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.5em 1.2em;
    border: 2px solid var(--color-navy);
    color: var(--color-navy);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  a.pagination-btn:hover {
    background: var(--color-navy);
    color: #fff;
  }

  .pagination-btn--disabled {
    opacity: 0.3;
    cursor: default;
    pointer-events: none;
  }

  .pagination-info {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-muted);
    white-space: nowrap;
  }
</style>

