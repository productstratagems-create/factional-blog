---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleGrid from '../../components/ArticleGrid.astro';
import Divider from '../../components/Divider.astro';
import { siteHref } from '../../utils/slug';

export async function getStaticPaths() {
  const PAGE_SIZE = 18;
  const allArticles = await getCollection('articles', (e) => !e.data.draft);
  const categories = [...new Set(allArticles.map((a) => a.data.category))];

  return categories.map((category) => {
    const catArticles = allArticles
      .filter((a) => a.data.category === category)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
    const totalPages = Math.ceil(catArticles.length / PAGE_SIZE);
    return {
      params: { category },
      props: {
        articles: catArticles.slice(0, PAGE_SIZE),
        category,
        total: catArticles.length,
        totalPages,
      },
    };
  });
}

const { articles, category, total, totalPages } = Astro.props;

const categoryLabels: Record<string, string> = {
  'missilforsvar':   'Missilforsvar',
  'missile-systems': 'Missilsystemer',
  'procurement':     'Anskaffelser',
  'anskaffelse':     'Anskaffelse',
  'policy':          'Forsvarspolitikk',
  'exercises':       'Øvelser',
  'history':         'Historie',
  'analyse':         'Analyse',
  'analysis':        'Analyse',
  'teknologi':       'Teknologi',
  'nato':            'NATO',
};

const label = categoryLabels[category] ?? category;
---

<BaseLayout
  title={label}
  description={`Alle artikler om ${label.toLowerCase()} på Norsk Luftvern.`}
>
  <div class="category-page">
    <div class="container">
      <header class="page-header">
        <p class="page-super" data-i18n="cat.label">Kategori</p>
        <h1 class="page-title">{label}</h1>
        <p class="article-count">{total} <span data-i18n={total === 1 ? 'cat.article' : 'cat.articles'}>{total === 1 ? 'artikkel' : 'artikler'}</span></p>
      </header>

      <Divider spacing="md" />

      <div class="articles-wrapper">
        <ArticleGrid articles={articles} columns={3} />
      </div>

      {totalPages > 1 && (
        <nav class="pagination" aria-label="Sidenavigasjon">
          <span class="pagination-btn pagination-btn--disabled" data-i18n="page.prev">← Forrige</span>
          <span class="pagination-info"><span data-i18n="page.page">Side</span> 1 <span data-i18n="page.of">av</span> {totalPages}</span>
          <a class="pagination-btn" href={siteHref(`/categories/${category}/page/2`)} data-i18n="page.next">Neste →</a>
        </nav>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .category-page { padding-bottom: var(--spacing-3xl); }

  .page-header {
    padding-block: var(--spacing-2xl) var(--spacing-xl);
  }

  .page-super {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-teal);
    margin-bottom: var(--spacing-sm);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-heading);
    line-height: 1;
    margin-bottom: var(--spacing-sm);
  }

  .article-count {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--color-muted);
    margin: 0;
  }

  .articles-wrapper { padding-block: var(--spacing-xl); }

  /* ── Pagination ── */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-md);
    padding-block: var(--spacing-xl) var(--spacing-2xl);
  }

  .pagination-btn {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.5em 1.2em;
    border: 2px solid var(--color-navy);
    color: var(--color-navy);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  a.pagination-btn:hover {
    background: var(--color-navy);
    color: #fff;
  }

  .pagination-btn--disabled {
    opacity: 0.3;
    cursor: default;
    pointer-events: none;
  }

  .pagination-info {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-muted);
    white-space: nowrap;
  }
</style>
