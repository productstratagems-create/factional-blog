---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Logger inn…" description="">
  <div class="callback-page container">
    <p class="callback-msg" data-i18n="login.redirecting">Logger inn…</p>
  </div>
</BaseLayout>

<script>
  import { supabase } from '../../lib/supabase';

  const code = new URL(location.href).searchParams.get('code');
  if (code) {
    const { error } = await supabase.auth.exchangeCodeForSession(code);
    if (!error) {
      const redirect = sessionStorage.getItem('login-redirect') || '/';
      sessionStorage.removeItem('login-redirect');
      location.replace(redirect);
    } else {
      location.replace('/login');
    }
  } else {
    location.replace('/');
  }
</script>

<style>
  .callback-page {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 50vh;
  }

  .callback-msg {
    font-family: var(--font-ui);
    font-size: 1rem;
    color: var(--color-muted);
  }
</style>
