---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroArticle from '../components/HeroArticle.astro';
import ArticleGrid from '../components/ArticleGrid.astro';
import Divider from '../components/Divider.astro';
import { articleHref, siteHref } from '../utils/slug';

const allArticles = await getCollection('articles', (e) => !e.data.draft);
const sorted = allArticles.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const featured = sorted.find((a) => a.data.featured) ?? sorted[0];
const rest = featured
  ? sorted.filter((a) => a.id !== featured.id).slice(0, 12)
  : sorted.slice(1, 13);

const featuredWordCount = featured?.body?.split(/\s+/).length ?? 0;
const featuredReadingTime = featured?.data.readingTimeMinutes ?? Math.max(1, Math.ceil(featuredWordCount / 200));
---

<BaseLayout
  title="Norsk Luftvern"
  description="Nyheter, analyser og dybdeartikler om norsk luftvern og missilforsvar."
>
  <div class="home-page">
    {featured && (
      <section class="hero-section container">
        <HeroArticle
          title={featured.data.title}
          excerpt={featured.data.excerpt}
          href={articleHref(featured.id)}
          heroImage={featured.data.heroImage}
          heroImageAlt={featured.data.heroImageAlt}
          category={featured.data.category}
          pubDate={featured.data.date}
          author={featured.data.author}
          readingTime={featuredReadingTime}
          lang={featured.data.lang}
        />
      </section>
    )}

    <Divider />

    <section class="articles-section container">
      <ArticleGrid articles={rest} columns={3} />

      {allArticles.length > 13 && (
        <div class="load-more">
          <a href={siteHref('/articles')} class="btn-outline" id="show-all-btn">Vis alle artikler</a>
          <div class="lang-shortcuts">
            <button class="lang-sc" data-lang="no">Norsk</button>
            <span class="lang-sc-sep">·</span>
            <button class="lang-sc" data-lang="en">English</button>
          </div>
        </div>
      )}
    </section>
  </div>
</BaseLayout>

<script>
  const articlesHref = document.getElementById('show-all-btn')?.getAttribute('href') ?? '/articles';
  document.querySelectorAll<HTMLButtonElement>('.lang-sc').forEach(btn => {
    btn.addEventListener('click', () => {
      localStorage.setItem('site-lang', btn.dataset.lang ?? 'all');
      window.location.href = articlesHref;
    });
  });
</script>

<style>
  .home-page {
    padding-bottom: var(--spacing-3xl);
  }

  .hero-section {
    padding-block: var(--spacing-lg);
  }

  .articles-section {
    padding-top: var(--spacing-lg);
    padding-bottom: var(--spacing-2xl);
  }

  .load-more {
    text-align: center;
    margin-top: var(--spacing-2xl);
  }

  .btn-outline {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.6em 1.6em;
    color: var(--color-navy);
    border: 2px solid var(--color-navy);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: background 0.15s, color 0.15s;
  }

  .btn-outline:hover {
    background: var(--color-navy);
    color: #fff;
  }

  .lang-shortcuts {
    margin-top: var(--spacing-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35em;
  }

  .lang-sc {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-navy);
    opacity: 0.55;
    padding: 0.2em 0.4em;
    transition: opacity 0.15s;
  }

  .lang-sc:hover {
    opacity: 1;
  }

  .lang-sc-sep {
    font-size: 0.7rem;
    color: var(--color-navy);
    opacity: 0.3;
  }
</style>
