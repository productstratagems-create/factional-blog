---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroArticle from '../components/HeroArticle.astro';
import ArticleGrid from '../components/ArticleGrid.astro';
import Divider from '../components/Divider.astro';
import { articleHref, siteHref } from '../utils/slug';
import { SERIES } from '../data/series';

const allArticles = await getCollection('articles', (e) => !e.data.draft);
const sorted = allArticles.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const seriesCards = Object.entries(SERIES).map(([slug, meta]) => ({
  slug,
  titleNo: meta.titleNo,
  titleEn: meta.titleEn,
  descriptionNo: meta.descriptionNo,
  descriptionEn: meta.descriptionEn,
  count: allArticles.filter((a) => a.data.series === slug).length,
})).filter((s) => s.count > 0);

const featuredNo = sorted.find((a) => a.data.featured && a.data.lang !== 'en')
  ?? sorted.find((a) => a.data.lang !== 'en') ?? sorted[0];
const featuredEn = sorted.find((a) => a.data.featured && a.data.lang === 'en')
  ?? sorted.find((a) => a.data.lang === 'en') ?? sorted[0];

const featuredIds = new Set([featuredNo?.id, featuredEn?.id].filter(Boolean));

const EDITORIAL_CATEGORIES = ['analyse', 'missilforsvar', 'luftvern'] as const;

const editorialSections = EDITORIAL_CATEGORIES.map(cat => ({
  cat,
  articles: sorted
    .filter(a => a.data.category === cat && !featuredIds.has(a.id))
    .slice(0, 3),
})).filter(s => s.articles.length > 0);

function readingTime(a: (typeof sorted)[0]) {
  const wc = a?.body?.split(/\s+/).length ?? 0;
  return a?.data.readingTimeMinutes ?? Math.max(1, Math.ceil(wc / 200));
}
---

<BaseLayout
  title="Norsk Luftvern"
  description="Nyheter, analyser og dybdeartikler om norsk luftvern og missilforsvar."
>
  <div class="home-page">
    {featuredNo && (
      <section class="hero-section container" data-article-lang="no">
        <HeroArticle
          title={featuredNo.data.title}
          excerpt={featuredNo.data.excerpt}
          href={articleHref(featuredNo.id)}
          heroImage={featuredNo.data.heroImage}
          heroImageAlt={featuredNo.data.heroImageAlt}
          category={featuredNo.data.category}
          pubDate={featuredNo.data.date}
          author={featuredNo.data.author}
          readingTime={readingTime(featuredNo)}
          lang={featuredNo.data.lang}
        />
      </section>
    )}
    {featuredEn && featuredEn.id !== featuredNo?.id && (
      <section class="hero-section container" data-article-lang="en">
        <HeroArticle
          title={featuredEn.data.title}
          excerpt={featuredEn.data.excerpt}
          href={articleHref(featuredEn.id)}
          heroImage={featuredEn.data.heroImage}
          heroImageAlt={featuredEn.data.heroImageAlt}
          category={featuredEn.data.category}
          pubDate={featuredEn.data.date}
          author={featuredEn.data.author}
          readingTime={readingTime(featuredEn)}
          lang={featuredEn.data.lang}
        />
      </section>
    )}

    <Divider />

    {seriesCards.length > 0 && (
      <section class="series-shelf container">
        <p class="series-shelf-label" data-i18n="series.header">Serier</p>
        <div class="series-shelf-cards">
          {seriesCards.map((s) => (
            <a href={siteHref(`/serier/${s.slug}`)} class="series-card">
              <span class="series-card-super" data-i18n="series.label">Serie</span>
              <span class="series-card-title">
                <span data-article-lang="no">{s.titleNo}</span>
                <span data-article-lang="en">{s.titleEn}</span>
              </span>
              <span class="series-card-desc">
                <span data-article-lang="no">{s.descriptionNo}</span>
                <span data-article-lang="en">{s.descriptionEn}</span>
              </span>
              <span class="series-card-footer">
                <span class="series-card-count">{s.count} <span data-i18n="series.parts">deler</span></span>
                <span class="series-card-cta" data-i18n="series.explore">Utforsk →</span>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    <Divider />

    {editorialSections.map(sec => (
      <section class="editorial-section container">
        <div class="editorial-header">
          <div class="editorial-header-left">
            <p class="editorial-eyebrow" data-i18n="cat.label">Kategori</p>
            <p class="editorial-label" data-i18n={`cat.name.${sec.cat}`}>
              {sec.cat === 'analyse' ? 'Analyse' : sec.cat === 'missilforsvar' ? 'Missilforsvar' : 'Luftvern'}
            </p>
          </div>
          <a href={siteHref(`/categories/${sec.cat}`)} class="editorial-see-all"
             data-i18n="series.see-all">Se alle →</a>
        </div>
        <ArticleGrid articles={sec.articles} columns={3} />
      </section>
    ))}

    <div class="load-more container">
      <a href={siteHref('/articles')} class="btn-outline" id="show-all-btn">Vis alle artikler</a>
      <div class="lang-shortcuts">
        <button class="lang-sc" data-lang="no">Norsk</button>
        <span class="lang-sc-sep">·</span>
        <button class="lang-sc" data-lang="en">English</button>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const articlesHref = document.getElementById('show-all-btn')?.getAttribute('href') ?? '/articles';
  document.querySelectorAll<HTMLButtonElement>('.lang-sc').forEach(btn => {
    btn.addEventListener('click', () => {
      localStorage.setItem('site-lang', btn.dataset.lang ?? 'all');
      window.location.href = articlesHref;
    });
  });
</script>

<style>
  .home-page {
    padding-bottom: var(--spacing-3xl);
  }

  .hero-section {
    padding-block: var(--spacing-lg);
  }

  .editorial-section {
    padding-top: var(--spacing-xl);
    padding-bottom: var(--spacing-lg);
  }

  .editorial-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--spacing-md);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--spacing-sm);
  }

  .editorial-header-left {
    display: flex;
    flex-direction: column;
    gap: 0.1em;
  }

  .editorial-eyebrow {
    font-family: var(--font-ui);
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-teal);
    margin: 0;
  }

  .editorial-label {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-heading);
    margin: 0;
  }

  .editorial-see-all {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-navy);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s;
  }

  .editorial-see-all:hover { color: var(--color-teal); }

  .load-more {
    text-align: center;
    padding-block: var(--spacing-xl) var(--spacing-2xl);
  }

  .btn-outline {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.6em 1.6em;
    color: var(--color-navy);
    border: 2px solid var(--color-navy);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: background 0.15s, color 0.15s;
  }

  .btn-outline:hover {
    background: var(--color-navy);
    color: #fff;
  }

  .lang-shortcuts {
    margin-top: var(--spacing-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35em;
  }

  .lang-sc {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-navy);
    opacity: 0.55;
    padding: 0.2em 0.4em;
    transition: opacity 0.15s;
  }

  .lang-sc:hover {
    opacity: 1;
  }

  .lang-sc-sep {
    font-size: 0.7rem;
    color: var(--color-navy);
    opacity: 0.3;
  }

  /* ── Series shelf ── */
  .series-shelf {
    padding-block: var(--spacing-xl) var(--spacing-lg);
  }

  .series-shelf-label {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-teal);
    margin-bottom: var(--spacing-md);
  }

  .series-shelf-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--spacing-md);
  }

  .series-card {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    padding: var(--spacing-md) var(--spacing-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-teal);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }

  .series-card:hover {
    border-color: var(--color-navy);
    border-left-color: var(--color-navy);
    background: var(--color-border);
  }

  .series-card-super {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-teal);
  }

  .series-card-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-heading);
    line-height: 1.15;
  }

  .series-card-desc {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.4;
    flex: 1;
  }

  .series-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--spacing-xs);
  }

  .series-card-count {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }

  .series-card-cta {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-navy);
  }
</style>
