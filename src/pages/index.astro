---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroArticle from '../components/HeroArticle.astro';
import ArticleGrid from '../components/ArticleGrid.astro';
import Divider from '../components/Divider.astro';
import { articleHref, siteHref } from '../utils/slug';
import { SERIES } from '../data/series';

const allArticles = await getCollection('articles', (e) => !e.data.draft);
const sorted = allArticles.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const seriesCards = Object.entries(SERIES).map(([slug, meta]) => ({
  slug,
  ...meta,
  count: allArticles.filter((a) => a.data.series === slug).length,
})).filter((s) => s.count > 0);

const featured = sorted.find((a) => a.data.featured) ?? sorted[0];
const rest = featured
  ? sorted.filter((a) => a.id !== featured.id).slice(0, 12)
  : sorted.slice(1, 13);

const featuredWordCount = featured?.body?.split(/\s+/).length ?? 0;
const featuredReadingTime = featured?.data.readingTimeMinutes ?? Math.max(1, Math.ceil(featuredWordCount / 200));
---

<BaseLayout
  title="Norsk Luftvern"
  description="Nyheter, analyser og dybdeartikler om norsk luftvern og missilforsvar."
>
  <div class="home-page">
    {featured && (
      <section class="hero-section container">
        <HeroArticle
          title={featured.data.title}
          excerpt={featured.data.excerpt}
          href={articleHref(featured.id)}
          heroImage={featured.data.heroImage}
          heroImageAlt={featured.data.heroImageAlt}
          category={featured.data.category}
          pubDate={featured.data.date}
          author={featured.data.author}
          readingTime={featuredReadingTime}
          lang={featured.data.lang}
        />
      </section>
    )}

    <Divider />

    {seriesCards.length > 0 && (
      <section class="series-shelf container">
        <p class="series-shelf-label" data-i18n="series.header">Serier</p>
        <div class="series-shelf-cards">
          {seriesCards.map((s) => (
            <a href={siteHref(`/serier/${s.slug}`)} class="series-card">
              <span class="series-card-super" data-i18n="series.label">Serie</span>
              <span class="series-card-title">{s.title}</span>
              <span class="series-card-desc">{s.description}</span>
              <span class="series-card-footer">
                <span class="series-card-count">{s.count} <span data-i18n="series.articles">artikler</span></span>
                <span class="series-card-cta" data-i18n="series.explore">Utforsk →</span>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="articles-section container">
      <ArticleGrid articles={rest} columns={3} />

      {allArticles.length > 13 && (
        <div class="load-more">
          <a href={siteHref('/articles')} class="btn-outline" id="show-all-btn">Vis alle artikler</a>
          <div class="lang-shortcuts">
            <button class="lang-sc" data-lang="no">Norsk</button>
            <span class="lang-sc-sep">·</span>
            <button class="lang-sc" data-lang="en">English</button>
          </div>
        </div>
      )}
    </section>
  </div>
</BaseLayout>

<script>
  const articlesHref = document.getElementById('show-all-btn')?.getAttribute('href') ?? '/articles';
  document.querySelectorAll<HTMLButtonElement>('.lang-sc').forEach(btn => {
    btn.addEventListener('click', () => {
      localStorage.setItem('site-lang', btn.dataset.lang ?? 'all');
      window.location.href = articlesHref;
    });
  });
</script>

<style>
  .home-page {
    padding-bottom: var(--spacing-3xl);
  }

  .hero-section {
    padding-block: var(--spacing-lg);
  }

  .articles-section {
    padding-top: var(--spacing-lg);
    padding-bottom: var(--spacing-2xl);
  }

  .load-more {
    text-align: center;
    margin-top: var(--spacing-2xl);
  }

  .btn-outline {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.6em 1.6em;
    color: var(--color-navy);
    border: 2px solid var(--color-navy);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: background 0.15s, color 0.15s;
  }

  .btn-outline:hover {
    background: var(--color-navy);
    color: #fff;
  }

  .lang-shortcuts {
    margin-top: var(--spacing-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35em;
  }

  .lang-sc {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-navy);
    opacity: 0.55;
    padding: 0.2em 0.4em;
    transition: opacity 0.15s;
  }

  .lang-sc:hover {
    opacity: 1;
  }

  .lang-sc-sep {
    font-size: 0.7rem;
    color: var(--color-navy);
    opacity: 0.3;
  }

  /* ── Series shelf ── */
  .series-shelf {
    padding-block: var(--spacing-xl) var(--spacing-lg);
  }

  .series-shelf-label {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-teal);
    margin-bottom: var(--spacing-md);
  }

  .series-shelf-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--spacing-md);
  }

  .series-card {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    padding: var(--spacing-md) var(--spacing-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-teal);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }

  .series-card:hover {
    border-color: var(--color-navy);
    border-left-color: var(--color-navy);
    background: var(--color-border);
  }

  .series-card-super {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-teal);
  }

  .series-card-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-heading);
    line-height: 1.15;
  }

  .series-card-desc {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.4;
    flex: 1;
  }

  .series-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--spacing-xs);
  }

  .series-card-count {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }

  .series-card-cta {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-navy);
  }
</style>
