---
import BaseLayout from './BaseLayout.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import ArticleMeta from '../components/ArticleMeta.astro';
import Divider from '../components/Divider.astro';
import ArticleGrid from '../components/ArticleGrid.astro';
import SeriesBanner from '../components/SeriesBanner.astro';
import TableOfContents from '../components/TableOfContents.astro';
import TagBadge from '../components/TagBadge.astro';
import WhereAreWeNow from '../components/WhereAreWeNow.astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { articleHref, siteHref, assetSrc } from '../utils/slug';
import { SERIES } from '../data/series';

interface Props {
  entry: CollectionEntry<'articles'>;
  related: CollectionEntry<'articles'>[];
  prev?: CollectionEntry<'articles'> | null;
  next?: CollectionEntry<'articles'> | null;
  headings?: { depth: number; slug: string; text: string }[];
  researchContext?: { summary: string; lastVerified: string } | null;
}

const { entry, related, prev = null, next = null, headings = [], researchContext = null } = Astro.props;
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const hasToc = tocHeadings.length >= 3;
const { title, excerpt, date, category, author, heroImage, heroImageAlt, lang = 'no', series, tags } = entry.data;

const wordCount = entry.body?.split(/\s+/).length ?? 0;
const readingTime = entry.data.readingTimeMinutes ?? Math.max(1, Math.ceil(wordCount / 200));

let seriesCount = 0;
let seriesPosition = 0;
let seriesPrev: CollectionEntry<'articles'> | null = null;
let seriesNext: CollectionEntry<'articles'> | null = null;

if (series) {
  const seriesArticles = (await getCollection('articles', (e) => !e.data.draft && e.data.series === series && e.data.lang === lang))
    .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
  seriesCount = seriesArticles.length;
  const seriesIdx = seriesArticles.findIndex(e => e.id === entry.id);
  seriesPosition = seriesIdx + 1;
  seriesPrev = seriesIdx > 0 ? seriesArticles[seriesIdx - 1] : null;
  seriesNext = seriesIdx < seriesArticles.length - 1 ? seriesArticles[seriesIdx + 1] : null;
}
---

<BaseLayout
  title={title}
  description={excerpt}
  ogType="article"
  pubDate={date}
  lang={lang}
  showProgress={true}
  ogImage={heroImage}
>
  <article class="article-page">
    <!-- Full-bleed hero -->
    <div class="article-hero">
      {heroImage ? (
        <img
          src={assetSrc(heroImage)}
          alt={heroImageAlt ?? ''}
          class="article-hero-image"
          loading="eager"
          decoding="async"
          width="1200"
          height="600"
        />
      ) : (
        <div class="article-hero-placeholder"></div>
      )}
      <div class="article-hero-overlay" aria-hidden="true"></div>
      <div class="article-hero-content container">
        <div class="hero-badges">
          <CategoryBadge category={category} href={siteHref(`/categories/${category}`)} />
          {tags && tags.length > 0 && tags.map(tag => <TagBadge tag={tag} />)}
        </div>
        <h1 class="article-title">{title}</h1>
        <ArticleMeta pubDate={date} author={author} readingTime={readingTime} lang={lang} />
      </div>
    </div>

    <!-- Prose body -->
    <div class="article-container container">
      <div class={`article-main${hasToc ? ' has-toc' : ''}`}>
        <div class="article-body-col">
          {series && seriesCount > 0 && (
            <SeriesBanner
              seriesSlug={series}
              seriesLabel={lang === 'en' ? (SERIES[series]?.titleEn ?? series) : (SERIES[series]?.titleNo ?? series)}
              totalCount={seriesCount}
              currentPosition={seriesPosition}
            />
          )}
          {hasToc && (
            <details class="toc-mobile">
              <summary class="toc-mobile-summary">
                <span class="toc-mobile-label" data-i18n="toc.label">Innhold</span>
                <span class="toc-mobile-meta">
                  {tocHeadings.length} <span data-i18n="toc.sections">seksjoner</span>
                </span>
                <svg class="toc-mobile-chevron" viewBox="0 0 12 12" aria-hidden="true">
                  <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </summary>
              <ol class="toc-mobile-list">
                {tocHeadings.map(h => (
                  <li class={`toc-mobile-item${h.depth === 3 ? ' toc-mobile-item--sub' : ''}`}>
                    <a href={`#${h.slug}`} class="toc-mobile-link">{h.text}</a>
                  </li>
                ))}
              </ol>
            </details>
          )}
          <div class="prose" id="article-body">
            <slot />
          </div>

          {researchContext && (
            <WhereAreWeNow
              summary={researchContext.summary}
              lastVerified={researchContext.lastVerified}
              lang={lang as 'no' | 'sv' | 'en'}
            />
          )}

          {(seriesPrev || seriesNext) && (
            <nav class="series-nav" aria-label="Serie-navigasjon">
              <p class="series-nav-label">
                <span data-i18n="series.label">Serie</span>: {lang === 'en' ? (SERIES[series!]?.titleEn ?? series) : (SERIES[series!]?.titleNo ?? series)}
              </p>
              <div class="series-nav-inner">
                {seriesPrev ? (
                  <a class="series-nav-link" href={articleHref(seriesPrev.id)}>
                    <span class="series-nav-dir" data-i18n="series.prev">← Forrige del</span>
                    <span class="series-nav-title">{seriesPrev.data.title}</span>
                  </a>
                ) : <span />}
                {seriesNext ? (
                  <a class="series-nav-link series-nav-link--next" href={articleHref(seriesNext.id)}>
                    <span class="series-nav-dir" data-i18n="series.next">Neste del →</span>
                    <span class="series-nav-title">{seriesNext.data.title}</span>
                  </a>
                ) : <span />}
              </div>
            </nav>
          )}
        </div>

        {hasToc && (
          <aside class="article-toc-col" aria-label="Innholdsfortegnelse">
            <TableOfContents headings={tocHeadings} />
          </aside>
        )}
      </div>

      <Divider spacing="lg" />

      {related.length > 0 && (
        <section class="related-section">
          <h2 class="related-heading" data-i18n="article.related">Les også</h2>
          <ArticleGrid articles={related} columns={2} />
        </section>
      )}

      {(prev || next) && (
        <nav class="article-nav" aria-label="Artikkelnavigasjon" data-i18n-aria="article.nav-aria">
          <div class="article-nav-inner">
            {next ? (
              <a class="article-nav-link article-nav-link--next" href={articleHref(next.id)}>
                <span class="article-nav-label" data-i18n="article.newer">← Nyere</span>
                <span class="article-nav-title">{next.data.title}</span>
              </a>
            ) : <span />}
            {prev ? (
              <a class="article-nav-link article-nav-link--prev" href={articleHref(prev.id)}>
                <span class="article-nav-label" data-i18n="article.older">Eldre →</span>
                <span class="article-nav-title">{prev.data.title}</span>
              </a>
            ) : <span />}
          </div>
        </nav>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  /* ── Hero ── */
  .article-hero {
    position: relative;
    width: 100%;
    min-height: clamp(300px, 45vw, 560px);
    overflow: hidden;
  }

  .article-hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-hero-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-heading) 0%, #1B3A7A 100%);
  }

  .article-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 3, 3, 0.9) 0%,
      rgba(10, 3, 3, 0.45) 60%,
      rgba(10, 3, 3, 0.05) 100%
    );
  }

  .article-hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: inherit;
    padding-bottom: var(--spacing-2xl);
    gap: var(--spacing-sm);
  }

  .hero-badges { margin-bottom: var(--spacing-sm); }

  .article-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 3rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.1;
    color: #fff;
    max-width: 22em;
    margin: 0;
  }

  .article-hero-content :global(.tag-badge) {
    color: rgba(255, 255, 255, 0.72);
    border-color: rgba(255, 255, 255, 0.28);
  }
  .article-hero-content :global(.tag-badge:hover) {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.65);
  }

  .article-hero-content :global(.article-meta) {
    color: rgba(255, 255, 255, 0.65);
    margin-top: var(--spacing-sm);
  }

  /* ── Article body ── */
  .article-container {
    padding-bottom: var(--spacing-3xl);
  }

  .article-main {
    padding-top: var(--spacing-2xl);
  }

  .article-main.has-toc {
    display: grid;
    grid-template-columns: minmax(0, var(--article-width, 720px)) 220px;
    column-gap: var(--spacing-2xl);
    align-items: start;
  }

  .article-toc-col {
    position: sticky;
    top: 5rem;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    scrollbar-width: none;
  }

  .article-toc-col::-webkit-scrollbar { display: none; }

  @media (max-width: 1080px) {
    .article-main.has-toc {
      display: block;
    }
    .article-toc-col {
      display: none;
    }
  }

  /* ── Mobile TOC ── */
  .toc-mobile { display: none; }

  @media (max-width: 1080px) {
    .toc-mobile {
      display: block;
      border: 1px solid var(--color-border);
      border-left: 3px solid var(--color-teal);
      border-radius: 0 var(--radius-md) var(--radius-md) 0;
      background: var(--color-surface);
      margin-bottom: var(--spacing-xl);
    }

    .toc-mobile-summary {
      display: flex;
      align-items: center;
      gap: var(--spacing-sm);
      padding: var(--spacing-sm) var(--spacing-md);
      cursor: pointer;
      list-style: none;
      user-select: none;
    }
    .toc-mobile-summary::-webkit-details-marker { display: none; }

    .toc-mobile-label {
      font-family: var(--font-ui);
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-teal);
    }

    .toc-mobile-meta {
      font-family: var(--font-ui);
      font-size: 0.7rem;
      color: var(--color-muted);
      flex: 1;
    }

    .toc-mobile-chevron {
      width: 12px;
      height: 12px;
      color: var(--color-muted);
      transition: transform 0.15s;
      flex-shrink: 0;
    }

    .toc-mobile[open] .toc-mobile-chevron {
      transform: rotate(180deg);
    }

    .toc-mobile-list {
      list-style: none;
      margin: 0;
      padding: var(--spacing-xs) 0 var(--spacing-sm);
      border-top: 1px solid var(--color-border);
    }

    .toc-mobile-item--sub .toc-mobile-link {
      padding-left: calc(var(--spacing-md) + 0.9rem);
      font-size: 0.8rem;
      opacity: 0.75;
    }

    .toc-mobile-link {
      display: block;
      padding: 0.35em var(--spacing-md);
      font-family: var(--font-ui);
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--color-navy);
      text-decoration: none;
      line-height: 1.3;
    }

    .toc-mobile-link:hover { text-decoration: underline; }
  }

  /* ── Series nav ── */
  .series-nav {
    margin-top: var(--spacing-2xl);
    padding: var(--spacing-md) var(--spacing-lg);
    background: var(--color-surface);
    border-left: 3px solid var(--color-teal);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    max-width: var(--article-width, 720px);
    margin-inline: auto;
    margin-top: var(--spacing-2xl);
  }

  .series-nav-label {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-teal);
    margin-bottom: var(--spacing-sm);
  }

  .series-nav-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-md);
  }

  .series-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25em;
    text-decoration: none;
    padding: var(--spacing-sm) var(--spacing-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: border-color 0.15s, background 0.15s;
  }

  .series-nav-link:hover {
    border-color: var(--color-teal);
    background: var(--color-bg);
  }

  .series-nav-link--next { text-align: right; }

  .series-nav-dir {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-teal);
  }

  .series-nav-title {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-heading);
    line-height: 1.2;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 600px) {
    .series-nav-inner { grid-template-columns: 1fr; }
    .series-nav-link--next { text-align: left; }
  }

  /* ── Prose typography ── */
  .prose {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.2vw, 1.125rem);
    line-height: 1.8;
    color: var(--color-text);
    max-width: var(--article-width, 720px);
    margin-inline: auto;
  }

  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-heading);
    margin-top: 2em;
    margin-bottom: 0.5em;
    line-height: 1.15;
  }

  .prose :global(h2) { font-size: 1.5rem; }
  .prose :global(h3) { font-size: 1.2rem; }

  .prose :global(p) { margin-bottom: 1.4em; }

  .prose :global(a) {
    color: var(--color-navy);
    text-decoration-color: var(--color-teal);
    text-underline-offset: 3px;
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--color-teal);
    margin-inline: 0;
    padding: var(--spacing-sm) var(--spacing-lg);
    background: var(--color-surface);
    font-style: italic;
    color: var(--color-muted);
  }

  .prose :global(blockquote p:last-child) { margin-bottom: 0; }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 1.4em;
  }

  .prose :global(li) { margin-bottom: 0.4em; }

  .prose :global(img) {
    width: 100%;
    border-radius: var(--radius-md);
    margin-block: var(--spacing-xl);
  }

  .prose :global(figure) { margin-block: var(--spacing-xl); }

  .prose :global(figcaption) {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-muted);
    text-align: center;
    margin-top: var(--spacing-sm);
  }

  .prose :global(hr) {
    border: none;
    border-top: 2px solid var(--color-teal);
    width: 3rem;
    margin: var(--spacing-2xl) auto;
  }

  .prose :global(code) {
    font-family: monospace;
    font-size: 0.875em;
    background: var(--color-surface);
    padding: 0.1em 0.3em;
    border-radius: 3px;
  }

  .prose :global(pre) {
    background: #1a1917;
    color: #e8e5e0;
    padding: var(--spacing-lg);
    overflow-x: auto;
    border-radius: var(--radius-md);
    margin-bottom: 1.4em;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
  }

  /* Drop cap */
  .prose :global(> p:first-of-type::first-letter) {
    font-family: var(--font-display);
    font-size: 3.5em;
    font-weight: 800;
    color: var(--color-heading);
    float: left;
    line-height: 0.82;
    margin: 0.06em 0.08em 0 0;
  }

  /* ── Related ── */
  .related-section { margin-top: var(--spacing-2xl); }

  .related-heading {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-heading);
    margin-bottom: var(--spacing-lg);
  }

  /* ── Prev/Next nav ── */
  .article-nav {
    margin-top: var(--spacing-2xl);
    padding-top: var(--spacing-xl);
    border-top: 2px solid var(--color-border);
  }

  .article-nav-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
  }

  .article-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.3em;
    text-decoration: none;
    padding: var(--spacing-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color 0.15s, background 0.15s;
  }

  .article-nav-link:hover {
    border-color: var(--color-navy);
    background: var(--color-surface);
  }

  .article-nav-link--prev {
    text-align: right;
    grid-column: 2;
  }

  .article-nav-label {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-teal);
  }

  .article-nav-title {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-heading);
    line-height: 1.2;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 600px) {
    .article-nav-inner {
      grid-template-columns: 1fr;
    }
    .article-nav-link--prev { grid-column: 1; text-align: left; }
  }
</style>

<script>
  document.querySelectorAll<HTMLAnchorElement>('.toc-mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      document.querySelector<HTMLDetailsElement>('.toc-mobile')?.removeAttribute('open');
    });
  });
</script>
