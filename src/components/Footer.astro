---
import { siteHref } from '../utils/slug';

const year = new Date().getFullYear();

const categories = [
  { href: siteHref('/categories/luftvern'),      label: 'Luftvern',      i18n: 'footer.cat.luftvern'      },
  { href: siteHref('/categories/missilforsvar'), label: 'Missilforsvar', i18n: 'footer.cat.missilforsvar' },
  { href: siteHref('/categories/teknologi'),        label: 'Teknologi',         i18n: 'footer.cat.teknologi'        },
  { href: siteHref('/categories/directed-energy'), label: 'Høyenergivåpen',    i18n: 'footer.cat.directed-energy'  },
  { href: siteHref('/categories/anskaffelse'),      label: 'Anskaffelser',      i18n: 'footer.cat.anskaffelse'      },
  { href: siteHref('/categories/analyse'),       label: 'Analyse',        i18n: 'footer.cat.analyse'       },
  { href: siteHref('/categories/history'),       label: 'Historie',       i18n: 'footer.cat.history'       },
];
---

<footer class="site-footer">
  <div class="footer-inner container">
    <div class="footer-brand">
      <a href={siteHref('/')} class="footer-wordmark" aria-label="Norsk Luftvern – forsiden">Norsk Luftvern</a>
      <p class="tagline" data-i18n="footer.tagline">Norges ledende kilde om luftvern og missilforsvar.</p>
    </div>

    <nav class="footer-nav" aria-label="Snarveier">
      <h3 data-i18n="footer.nav-heading">Navigasjon</h3>
      <ul role="list">
        <li><a href={siteHref('/')} data-i18n="footer.home">Forsiden</a></li>
        <li><a href={siteHref('/serier')} data-i18n="nav.series">Serier</a></li>
        <li><a href={siteHref('/tags')} data-i18n="tags.label">Stikkord</a></li>
        <li><a href={siteHref('/about')} data-i18n="footer.about">Om oss</a></li>
        <li><a href={siteHref('/rss.xml')} data-i18n="footer.rss">RSS-feed</a></li>
      </ul>
    </nav>

    <nav class="footer-nav" aria-label="Kategorier">
      <h3 data-i18n="footer.cats-heading">Kategorier</h3>
      <ul role="list">
        {categories.map(({ href, label, i18n }) => (
          <li><a href={href} data-i18n={i18n}>{label}</a></li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {year} Norsk Luftvern. <span data-i18n="footer.copy">Alle rettigheter forbeholdt.</span></p>
      <a href={siteHref('/rss.xml')} class="rss-link" aria-label="RSS-feed">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <circle cx="2.5" cy="13.5" r="1.5"/>
          <path d="M1 7.5A6.5 6.5 0 0 1 7.5 14H9A7.5 7.5 0 0 0 1 6.5v1z"/>
          <path d="M1 3.5A10.5 10.5 0 0 1 11.5 14H13A12 12 0 0 0 1 2v1.5z"/>
        </svg>
        RSS
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #1C0808;
    color: rgba(255,255,255,0.75);
    margin-top: var(--spacing-3xl);
  }

  :global([data-theme="dark"]) .site-footer {
    background: #0D1117;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: var(--spacing-2xl);
    padding-block: var(--spacing-2xl);
  }

  .footer-wordmark {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.9);
    text-decoration: none;
    display: inline-block;
  }

  .tagline {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    line-height: 1.6;
    margin-top: var(--spacing-md);
    opacity: 0.65;
  }

  .footer-nav h3 {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-teal);
    margin-bottom: var(--spacing-md);
  }

  .footer-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }

  .footer-nav a {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-nav a:hover { color: #fff; }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-block: var(--spacing-md);
  }

  .footer-bottom .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--spacing-md);
  }

  .footer-bottom p {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    opacity: 0.5;
    margin: 0;
  }

  .rss-link {
    display: flex;
    align-items: center;
    gap: 0.3em;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-teal);
    text-decoration: none;
    opacity: 0.85;
    transition: opacity 0.15s;
  }

  .rss-link:hover { opacity: 1; }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: var(--spacing-xl);
      padding-block: var(--spacing-xl);
    }

    .footer-bottom .container {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--spacing-sm);
    }
  }
</style>
