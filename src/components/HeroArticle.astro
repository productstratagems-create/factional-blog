---
import ArticleMeta from './ArticleMeta.astro';
import { assetSrc } from '../utils/slug';

interface Props {
  title: string;
  excerpt: string;
  href: string;
  heroImage?: string;
  heroImageAlt?: string;
  category: string;
  pubDate: Date;
  author?: string;
  readingTime?: number;
  lang?: string;
}

const {
  title,
  excerpt,
  href,
  heroImage,
  heroImageAlt = '',
  pubDate,
  author = 'Redaksjonen',
  readingTime,
  lang = 'no',
} = Astro.props;
---

<div class="hero-wrap">
  <a href={href} class="hero-card" aria-label={title}>
    {heroImage ? (
      <img
        src={assetSrc(heroImage)}
        alt={heroImageAlt}
        class="hero-image"
        loading="eager"
        decoding="async"
        width="1200"
        height="600"
      />
    ) : (
      <div class="hero-placeholder"></div>
    )}

    <div class="hero-overlay" aria-hidden="true"></div>

    <div class="hero-content">
      <h1 class="hero-title">{title}</h1>
      <p class="hero-excerpt">{excerpt}</p>
      <div class="hero-meta">
        <ArticleMeta pubDate={pubDate} author={author} readingTime={readingTime} lang={lang} />
        <span class="read-more">Les mer →</span>
      </div>
    </div>
  </a>
</div>

<style>
  .hero-wrap { width: 100%; }

  .hero-card {
    position: relative;
    display: block;
    width: 100%;
    min-height: clamp(360px, 50vw, 600px);
    overflow: hidden;
    text-decoration: none;
    border-radius: var(--radius-md);
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .hero-card:hover .hero-image { transform: scale(1.03); }

  .hero-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-heading) 0%, #3D1515 60%, #1B3A7A 100%);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 3, 3, 0.92) 0%,
      rgba(10, 3, 3, 0.50) 45%,
      rgba(10, 3, 3, 0.0) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    min-height: inherit;
    padding: var(--spacing-lg);
    gap: var(--spacing-sm);
  }

  @media (min-width: 769px) {
    .hero-content { padding: var(--spacing-xl); }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.8rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.1;
    color: #fff;
    margin: 0;
    max-width: 22em;
  }

  .hero-excerpt {
    font-family: var(--font-body);
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    line-height: 1.6;
    color: rgba(255,255,255,0.8);
    margin: 0;
    max-width: 60ch;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-xs);
  }

  .hero-meta :global(.article-meta) { color: rgba(255,255,255,0.65); }

  .read-more {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-teal);
    letter-spacing: 0.04em;
    white-space: nowrap;
    transition: color 0.15s;
  }

  .hero-card:hover .read-more { color: #fff; }

  @media (max-width: 600px) {
    .hero-excerpt { display: none; }
  }
</style>
