---
import { assetSrc } from '../utils/slug';

interface Props {
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { size = 'md', class: className } = Astro.props;

// Logo is a 640×640 square with ~25% white padding on each side.
// Use a wide container with object-fit:cover to crop to the wordmark content.
const dims = {
  sm: { h: 32,  w: 112 },
  md: { h: 44,  w: 154 },
  lg: { h: 58,  w: 203 },
};
const { h, w } = dims[size];

const src = assetSrc('/images/IMG_9667.jpeg');
---

<a href={import.meta.env.BASE_URL} class:list={['logo', className]} aria-label="Norsk Luftvern – forsiden">
  <img
    src={src}
    alt="Norsk Luftvern"
    width={w}
    height={h}
    style={`width:${w}px;height:${h}px;`}
    loading="eager"
    decoding="async"
  />
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    line-height: 1;
  }

  .logo img {
    display: block;
    object-fit: cover;
    object-position: center center;
  }

  :global([data-theme="dark"]) .logo {
    background: var(--color-bg);
    isolation: isolate;
  }

  :global([data-theme="dark"]) .logo img {
    filter: invert(1);
    mix-blend-mode: screen;
  }
</style>
