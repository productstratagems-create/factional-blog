---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { size = 'md', class: className } = Astro.props;

const sizes = {
  sm: { fontSize: '1rem',  iconH: 28 },
  md: { fontSize: '1.35rem', iconH: 38 },
  lg: { fontSize: '2rem',  iconH: 56 },
};

const { fontSize, iconH } = sizes[size];
// unique prefix avoids duplicate SVG marker IDs when logo renders in header + footer
const uid = Math.random().toString(36).slice(2, 8);
---

<a href={import.meta.env.BASE_URL} class:list={['logo', className]} aria-label="Norsk Luftvern – forsiden" style={`--logo-font-size: ${fontSize}; --logo-icon-h: ${iconH}px`}>
  <span class="logo__word" aria-hidden="true">Norsk</span>

  <!-- Missile-arc icon -->
  <svg
    class="logo__icon"
    viewBox="0 0 46 50"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    focusable="false"
  >
    <defs>
      <marker
        id={`arr-${uid}`}
        markerWidth="5"
        markerHeight="4"
        refX="4.5"
        refY="2"
        orient="auto"
      >
        <polygon points="0 0, 5 2, 0 4" fill="#1B3A7A" />
      </marker>
    </defs>
    <!-- three sweeping arcs, bottom-left → upper-right -->
    <path
      d="M 2,46 Q 8,28 20,10"
      stroke="#1B3A7A"
      stroke-width="2.4"
      stroke-linecap="round"
      marker-end={`url(#arr-${uid})`}
    />
    <path
      d="M 14,46 Q 20,28 32,10"
      stroke="#1B3A7A"
      stroke-width="2.4"
      stroke-linecap="round"
      marker-end={`url(#arr-${uid})`}
    />
    <path
      d="M 24,46 Q 30,30 42,14"
      stroke="#1B3A7A"
      stroke-width="2.4"
      stroke-linecap="round"
      marker-end={`url(#arr-${uid})`}
    />
  </svg>

  <span class="logo__word" aria-hidden="true">Luftvern</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    text-decoration: none;
    line-height: 1;
  }

  .logo__word {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--logo-font-size);
    color: var(--color-heading);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    white-space: nowrap;
  }

  .logo__icon {
    height: var(--logo-icon-h);
    width: auto;
    flex-shrink: 0;
    /* nudge icon up slightly to align with cap-height */
    transform: translateY(-6%);
  }
</style>
