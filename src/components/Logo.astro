---
import { assetSrc } from '../utils/slug';

interface Props {
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { size = 'md', class: className } = Astro.props;

// 2:1 crop that eliminates the white padding around the logo content.
// object-fit:cover + object-position:center shows rows 25%–75% of the square
// image, which is exactly where the missile icon (31%) and text (58–70%) live.
const dims = {
  sm: { h: 40,  w: 80  },
  md: { h: 58,  w: 116 },
  lg: { h: 78,  w: 156 },
};
const { h, w } = dims[size];

const src = assetSrc('/images/image.jpg');
---

<a href={import.meta.env.BASE_URL} class:list={['logo', className]} aria-label="Norsk Luftvern – forsiden">
  <img
    src={src}
    alt="Norsk Luftvern"
    width={w}
    height={h}
    style={`width:${w}px;height:${h}px;`}
    loading="eager"
    decoding="async"
  />
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    line-height: 1;
  }

  .logo img {
    display: block;
    object-fit: cover;
    object-position: center center;
  }
</style>
