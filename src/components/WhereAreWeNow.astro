---
interface Props {
  summary: string;
  lastVerified: string;  // ISO date "YYYY-MM-DD"
  lang?: 'no' | 'sv' | 'en';
}

const { summary, lastVerified, lang = 'no' } = Astro.props;

const heading   = lang === 'en' ? 'Where Are We Now?' : 'Hvor står vi i dag?';
const label     = lang === 'en' ? 'Research updated' : 'Analyse oppdatert';
const disclaimer =
  lang === 'en'
    ? 'Synthesised from open sources. May not reflect the latest developments.'
    : 'Oppsummert fra åpne kilder. Kan hende ikke gjenspeiler siste utvikling.';

// Format the date in the article's locale
const verifiedDate = new Date(lastVerified + 'T00:00:00Z').toLocaleDateString(
  lang === 'en' ? 'en-GB' : lang === 'sv' ? 'sv-SE' : 'nb-NO',
  { year: 'numeric', month: 'long', day: 'numeric' },
);

// Split summary into paragraphs
const paragraphs = summary.split(/\n{2,}/).map(p => p.trim()).filter(Boolean);
---

<aside class="where-now" aria-label={heading}>
  <div class="where-now-header">
    <span class="where-now-eyebrow">&#9632;</span>
    <h2 class="where-now-heading">{heading}</h2>
    <span class="where-now-date">{label}: {verifiedDate}</span>
  </div>

  <div class="where-now-body">
    {paragraphs.map(p => <p>{p}</p>)}
  </div>

  <p class="where-now-disclaimer">{disclaimer}</p>
</aside>

<style>
  .where-now {
    max-width: var(--article-width, 720px);
    margin-inline: auto;
    margin-block: var(--spacing-2xl);
    border-left: 4px solid var(--color-teal);
    background: var(--color-surface);
    padding: var(--spacing-lg) var(--spacing-xl);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .where-now-header {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5em 1em;
    margin-bottom: var(--spacing-md);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--spacing-sm);
  }

  .where-now-eyebrow {
    color: var(--color-teal);
    font-size: 0.6rem;
    flex-shrink: 0;
  }

  .where-now-heading {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-heading);
    margin: 0;
    flex: 1;
  }

  .where-now-date {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .where-now-body {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--color-text);
  }

  .where-now-body p {
    margin-bottom: 0.9em;
  }

  .where-now-body p:last-child {
    margin-bottom: 0;
  }

  .where-now-disclaimer {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    color: var(--color-muted);
    margin: var(--spacing-sm) 0 0;
    font-style: italic;
  }
</style>
