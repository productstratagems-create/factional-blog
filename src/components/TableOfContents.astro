---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

{tocHeadings.length >= 3 && (
  <nav class="toc" aria-label="Innholdsfortegnelse">
    <p class="toc-title" data-i18n="toc.label">Innhold</p>
    <ol class="toc-list">
      {tocHeadings.map(h => (
        <li class={`toc-item${h.depth === 3 ? ' toc-item--sub' : ''}`}>
          <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
        </li>
      ))}
    </ol>
  </nav>
)}

<script>
  (() => {
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (links.length === 0) return;

    const headingEls = document.querySelectorAll<HTMLElement>('#article-body h2, #article-body h3');
    let activeLink: HTMLAnchorElement | null = null;

    function setActive(id: string) {
      const next = document.querySelector<HTMLAnchorElement>(`.toc-link[href="#${id}"]`);
      if (next === activeLink) return;
      activeLink?.classList.remove('toc-link--active');
      next?.classList.add('toc-link--active');
      activeLink = next;
      next?.scrollIntoView({ block: 'nearest' });
    }

    const observer = new IntersectionObserver(
      entries => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
          }
        }
      },
      { rootMargin: '-8% 0px -80% 0px', threshold: 0 }
    );

    headingEls.forEach(el => observer.observe(el));
  })();
</script>

<style>
  .toc {
    padding: var(--spacing-md) var(--spacing-md) var(--spacing-md) 0;
    border-left: 2px solid var(--color-border);
  }

  .toc-title {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-teal);
    margin: 0 0 var(--spacing-sm) var(--spacing-md);
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toc-item {
    margin: 0;
    padding: 0;
  }

  .toc-item--sub .toc-link {
    padding-left: calc(var(--spacing-md) + 0.9rem);
    font-size: 0.75rem;
    opacity: 0.75;
  }

  .toc-link {
    display: block;
    padding: 0.3em var(--spacing-md);
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    line-height: 1.35;
    border-left: 2px solid transparent;
    margin-left: -2px;
    transition: color 0.12s, border-color 0.12s;
  }

  .toc-link:hover {
    color: var(--color-navy);
    border-left-color: var(--color-border);
  }

  .toc-link--active {
    color: var(--color-navy);
    border-left-color: var(--color-teal);
    font-weight: 600;
    opacity: 1 !important;
  }
</style>
