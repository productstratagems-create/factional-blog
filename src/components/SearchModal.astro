---
import { getCollection } from 'astro:content';
import { articleHref, siteHref } from '../utils/slug';

// Strip markdown syntax to plain searchable text
function extractText(raw = '') {
  return raw
    .replace(/!\[.*?\]\(.*?\)/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/^#{1,6}\s+/gm, '')
    .replace(/`{1,3}[\s\S]*?`{1,3}/g, ' ')
    .replace(/[*_]{1,3}([^*_\n]+)[*_]{1,3}/g, '$1')
    .replace(/^\|.*$/gm, '')
    .replace(/^\s*[-*+>]\s+/gm, '')
    .replace(/&[a-z]+;/g, ' ')
    .replace(/<[^>]+>/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

const articles = await getCollection('articles', ({ data }) => !data.draft);
const searchIndex = articles
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map(entry => {
    const plain = extractText(entry.body ?? '');
    const firstPara = plain.split(/\s{2,}/).find(s => s.trim().length > 25) ?? '';
    return {
      title:     entry.data.title,
      href:      articleHref(entry.id),
      date:      entry.data.date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' }),
      firstPara: firstPara.slice(0, 250),
      body:      plain.slice(0, 500),
      lang:      entry.data.lang ?? 'no',
    };
  });

const tagMap = new Map<string, { no: number; en: number }>();
for (const entry of articles) {
  for (const tag of entry.data.tags ?? []) {
    const cur = tagMap.get(tag) ?? { no: 0, en: 0 };
    if (entry.data.lang === 'en') cur.en++; else cur.no++;
    tagMap.set(tag, cur);
  }
}
const tagCloud = [...tagMap.entries()]
  .map(([tag, counts]) => ({
    tag,
    href: siteHref(`/tags/${tag}`),
    no: counts.no,
    en: counts.en,
  }))
  .filter(t => t.no + t.en > 0);
---

<dialog class="search-dialog" id="search-dialog" aria-label="Søk i artikler">
  <div class="search-panel">

    <div class="search-input-row">
      <svg class="search-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor"
           stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
        <circle cx="8.5" cy="8.5" r="5.25"/>
        <line x1="12.5" y1="12.5" x2="17" y2="17"/>
      </svg>
      <input
        id="search-input"
        type="search"
        class="search-input"
        placeholder="Søk i artikler…"
        data-i18n-placeholder="search.placeholder"
        autocomplete="off"
        spellcheck="false"
        aria-label="Søk"
        aria-autocomplete="list"
        aria-controls="search-listbox"
        aria-haspopup="listbox"
      />
      <button class="search-close-btn" id="search-close" aria-label="Lukk søk">
        <kbd>Esc</kbd>
      </button>
    </div>

    <div id="search-idle-cloud" class="search-idle-cloud" hidden>
      <p class="search-idle-label" data-i18n="tags.label">Stikkord</p>
      <div class="search-idle-tags" role="list"></div>
    </div>

    <ul class="search-listbox" id="search-listbox" role="listbox" aria-label="Søkeresultater"></ul>

    <div class="search-footer">
      <span class="search-status" id="search-status" aria-live="polite" aria-atomic="true">
        Søk blant {searchIndex.length} artikler
      </span>
      <span class="search-keys" aria-hidden="true">
        <kbd>↑</kbd><kbd>↓</kbd> <span data-i18n="search.navigate">naviger</span> &ensp;
        <kbd>↵</kbd> <span data-i18n="search.open-key">åpne</span> &ensp;
        <kbd>Esc</kbd> <span data-i18n="search.close-key">lukk</span>
      </span>
    </div>

  </div>
</dialog>

<script define:vars={{ searchIndex, tagCloud }}>
  const SEARCH_T = {
    no: {
      among:   (n) => `Søk blant ${n} artikler`,
      result:  (n) => n === 1 ? `${n} resultat` : `${n} resultater`,
      none:    (q) => `Ingen artikler matcher «${q}»`,
      tryOther: 'Prøv et annet søkeord.',
      tier2: 'Ingress',
      tier1: 'Tekst',
      tier3: 'Tittel',
      tierHits: (n) => `${n} treff`,
    },
    en: {
      among:   (n) => `Search among ${n} articles`,
      result:  (n) => n === 1 ? `${n} result` : `${n} results`,
      none:    (q) => `No articles match «${q}»`,
      tryOther: 'Try a different search term.',
      tier2: 'Lead',
      tier1: 'Body',
      tier3: 'Title',
      tierHits: (n) => `${n} result${n === 1 ? '' : 's'}`,
    },
  };

  function sl() {
    return document.documentElement.getAttribute('data-lang-filter') === 'en' ? 'en' : 'no';
  }

  const dialog   = document.getElementById('search-dialog');
  const input    = document.getElementById('search-input');
  const listbox  = document.getElementById('search-listbox');
  const status   = document.getElementById('search-status');
  const closeBtn = document.getElementById('search-close');

  let activeIdx   = -1;
  let lastTrigger = null;
  let debounce    = null;

  // ── Open / Close ─────────────────────────────────────────────

  function openSearch(trigger = null) {
    lastTrigger = trigger;
    input.value = '';
    activeIdx = -1;
    renderIdle();
    dialog.showModal();
    requestAnimationFrame(() => input.focus());
  }

  function closeSearch() {
    dialog.close();
    lastTrigger?.focus();
  }

  dialog.addEventListener('click', e => { if (e.target === dialog) closeSearch(); });
  dialog.addEventListener('cancel', e => { e.preventDefault(); closeSearch(); });
  closeBtn.addEventListener('click', closeSearch);
  document.getElementById('search-idle-cloud')?.addEventListener('click', closeSearch);

  document.querySelectorAll('.search-btn').forEach(btn =>
    btn.addEventListener('click', () => openSearch(btn))
  );

  document.addEventListener('keydown', e => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      dialog.open ? closeSearch() : openSearch();
    }
  });

  // ── Input ────────────────────────────────────────────────────

  input.addEventListener('input', () => {
    clearTimeout(debounce);
    debounce = setTimeout(() => { activeIdx = -1; renderResults(input.value); }, 80);
  });

  // ── Keyboard navigation ──────────────────────────────────────

  input.addEventListener('keydown', e => {
    const items = [...listbox.querySelectorAll('[role="option"]')]
      .filter(el => !el.classList.contains('is-hidden'));
    if (!items.length) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      setActive(Math.min(activeIdx + 1, items.length - 1), items);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setActive(activeIdx <= 0 ? -1 : activeIdx - 1, items);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      const target = activeIdx >= 0 ? items[activeIdx] : items[0];
      target?.querySelector('a')?.click();
    }
  });

  function setActive(idx, items) {
    items.forEach((el, i) => {
      el.setAttribute('aria-selected', i === idx ? 'true' : 'false');
      el.classList.toggle('is-active', i === idx);
    });
    activeIdx = idx;
    if (idx >= 0) {
      input.setAttribute('aria-activedescendant', items[idx].id);
      items[idx].scrollIntoView({ block: 'nearest' });
    } else {
      input.removeAttribute('aria-activedescendant');
    }
  }

  // ── Helpers ──────────────────────────────────────────────────

  function escRe(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

  function highlight(text, q) {
    if (!q) return text;
    return text.replace(new RegExp(`(${escRe(q)})`, 'gi'), '<mark>$1</mark>');
  }

  function getSnippet(text, q, maxLen = 150) {
    const idx = text.toLowerCase().indexOf(q.toLowerCase());
    if (idx < 0) return text.slice(0, maxLen) + (text.length > maxLen ? '…' : '');
    const start = Math.max(0, idx - 55);
    const end   = Math.min(text.length, start + maxLen);
    return (start > 0 ? '…' : '') + text.slice(start, end) + (end < text.length ? '…' : '');
  }

  function resultHTML(a, score, i, q, hidden = false) {
    const t = SEARCH_T[sl()];
    const titleHTML = highlight(a.title, q);

    let snipHTML  = '';
    let tierLabel = '';

    if (score === 2) {
      snipHTML  = `<span class="si-snip">${highlight(getSnippet(a.firstPara, q), q)}</span>`;
      tierLabel = `<span class="si-tier">${t.tier2}</span>`;
    } else if (score === 1) {
      snipHTML  = `<span class="si-snip">${highlight(getSnippet(a.body, q), q)}</span>`;
      tierLabel = `<span class="si-tier">${t.tier1}</span>`;
    }

    const hiddenClass = hidden ? ' is-hidden' : '';

    return `
      <li id="search-result-${i}" role="option" aria-selected="false"
          class="search-item search-item--tier${score}${hiddenClass}">
        <a href="${a.href}" class="search-item-link">
          <span class="si-content">
            <span class="si-title">${titleHTML}</span>
            ${snipHTML}
          </span>
          <span class="si-meta">
            ${tierLabel}
            <span class="si-date">${a.date}</span>
          </span>
        </a>
      </li>`;
  }

  function tierHeaderHTML(label, count, open) {
    const t = SEARCH_T[sl()];
    return `
      <li class="tier-section" data-open="${open}" role="presentation">
        <button class="tier-toggle" type="button">
          <span class="tier-toggle-chevron" aria-hidden="true"></span>
          <span class="tier-toggle-label">${label}</span>
          <span class="tier-toggle-count">${t.tierHits(count)}</span>
        </button>
      </li>`;
  }

  function attachResultListeners() {
    listbox.querySelectorAll('a').forEach(a => a.addEventListener('click', closeSearch));
    listbox.querySelectorAll('.tier-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const header = btn.closest('.tier-section');
        const isOpen = header.dataset.open === 'true';
        header.dataset.open = String(!isOpen);
        let sib = header.nextElementSibling;
        while (sib && !sib.classList.contains('tier-section')) {
          sib.classList.toggle('is-hidden', isOpen);
          sib = sib.nextElementSibling;
        }
      });
    });
  }

  // ── Render ───────────────────────────────────────────────────

  function renderIdle() {
    const lang = sl();
    const langCount = searchIndex.filter(a => a.lang === lang).length;
    status.textContent = SEARCH_T[lang].among(langCount);
    input.removeAttribute('aria-activedescendant');
    listbox.removeAttribute('data-has-results');
    listbox.innerHTML = '';

    const cloud = document.getElementById('search-idle-cloud');
    const tagsContainer = cloud?.querySelector('.search-idle-tags');
    if (cloud && tagsContainer) {
      const topTags = tagCloud
        .filter(t => lang === 'en' ? t.en > 0 : t.no > 0)
        .sort((a, b) => lang === 'en' ? b.en - a.en : b.no - a.no)
        .slice(0, 20);
      tagsContainer.innerHTML = '';
      topTags.forEach(t => {
        const a = document.createElement('a');
        a.href = t.href;
        a.textContent = t.tag;
        a.className = 'search-idle-tag';
        a.setAttribute('role', 'listitem');
        tagsContainer.appendChild(a);
      });
      cloud.hidden = topTags.length === 0;
    }
  }

  function renderResults(query) {
    const t  = SEARCH_T[sl()];
    const q  = query.trim();
    const ql = q.toLowerCase();

    if (!q) { renderIdle(); return; }

    const cloud = document.getElementById('search-idle-cloud');
    if (cloud) cloud.hidden = true;

    const activeLang = sl();
    // Rank: title match (3) > first-paragraph match (2) > body match (1)
    const scored = searchIndex
      .filter(a => a.lang === activeLang)
      .map(a => {
        const score = a.title.toLowerCase().includes(ql) ? 3
          : a.firstPara.toLowerCase().includes(ql)       ? 2
          : a.body.toLowerCase().includes(ql)            ? 1
          : 0;
        return { a, score };
      })
      .filter(x => x.score > 0)
      .sort((x, y) => y.score - x.score);

    const total = scored.length;
    status.textContent = total ? t.result(total) : t.none(q);

    listbox.setAttribute('data-has-results', '');

    if (!total) {
      listbox.innerHTML = `<li class="no-results">${t.none('<strong>' + q + '</strong>')} ${t.tryOther}</li>`;
      return;
    }

    const t3 = scored.filter(x => x.score === 3);
    const t2 = scored.filter(x => x.score === 2);
    const t1 = scored.filter(x => x.score === 1);

    // Auto-expand lower tiers when there are no title matches
    const startOpen = t3.length === 0;

    let html = '';
    let idx = 0;

    if (t3.length) {
      html += tierHeaderHTML(t.tier3, t3.length, true);
      t3.forEach(({ a, score }) => { html += resultHTML(a, score, idx++, q, false); });
    }

    if (t2.length) {
      html += tierHeaderHTML(t.tier2, t2.length, startOpen);
      t2.forEach(({ a, score }) => {
        html += resultHTML(a, score, idx++, q, !startOpen);
      });
    }

    if (t1.length) {
      html += tierHeaderHTML(t.tier1, t1.length, startOpen);
      t1.forEach(({ a, score }) => {
        html += resultHTML(a, score, idx++, q, !startOpen);
      });
    }

    listbox.innerHTML = html;
    attachResultListeners();
  }

  // Re-render when lang changes while modal is open
  document.addEventListener('i18n:change', () => {
    if (!dialog.open) return;
    input.value.trim() ? renderResults(input.value) : renderIdle();
  });
</script>

<style>
  .search-dialog {
    padding: 0;
    border: none;
    border-radius: var(--radius-md);
    background: transparent;
    overflow: visible;
    width: min(640px, 94vw);
    max-height: 85vh;
    margin-top: 10vh;
    margin-inline: auto;
    opacity: 0;
    transform: translateY(-10px) scale(0.98);
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .search-dialog[open] {
    opacity: 1;
    transform: none;
  }

  .search-dialog::backdrop {
    background: rgba(10, 3, 3, 0.5);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
  }

  .search-panel {
    background: var(--color-bg);
    border-radius: var(--radius-md);
    box-shadow: 0 24px 64px rgba(0,0,0,0.25), 0 0 0 1px rgba(0,0,0,0.07);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: 85vh;
  }

  /* ── Input ── */
  .search-input-row {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .search-icon { width: 18px; height: 18px; color: var(--color-muted); flex-shrink: 0; }

  .search-input {
    flex: 1;
    border: none;
    outline: none;
    font-family: var(--font-ui);
    font-size: 1rem;
    color: var(--color-text);
    background: transparent;
    min-width: 0;
    caret-color: var(--color-teal);
  }

  .search-input::placeholder { color: var(--color-muted); }
  .search-input::-webkit-search-cancel-button { display: none; }

  .search-close-btn {
    flex-shrink: 0;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    border-radius: 5px;
    cursor: pointer;
    padding: 3px 8px;
    transition: background 0.12s;
  }

  .search-close-btn:hover { background: var(--color-border); }

  .search-close-btn kbd {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-muted);
    pointer-events: none;
  }

  /* ── List ── */

  /* Collapsed by default — expands only when results are present */
  .search-listbox {
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 0 0 0;
    overflow: hidden;
    scroll-padding-block: 0.4rem;
  }

  .search-listbox[data-has-results] {
    flex: 1 1 auto;
    padding: 0.4rem 0;
    overflow-y: auto;
  }

  /* Footer gets a top border only when separated from a result list */
  .search-listbox[data-has-results] + .search-footer {
    border-top: 1px solid var(--color-border);
  }

  /* ── Result rows — all injected via innerHTML, must use :global ── */

  :global(.no-results) {
    padding: 1.75rem 1rem;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--color-muted);
    text-align: center;
  }
  :global(.no-results strong) { color: var(--color-heading); }

  :global(.search-item) { display: block; }

  :global(.search-item-link) {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 0.65rem 1.25rem 0.65rem calc(1.25rem - 3px);
    border-left: 3px solid transparent;
    text-decoration: none;
    color: inherit;
    transition: background 0.1s, border-color 0.12s;
    outline: none;
  }

  :global(.search-item-link:hover) {
    background: var(--color-surface);
  }

  :global(.search-item.is-active .search-item-link) {
    background: var(--color-surface);
    border-left-color: var(--color-teal);
  }

  :global(.si-content) {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  :global(.si-title) {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-heading);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.si-snip) {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--color-muted);
    line-height: 1.45;
    white-space: normal;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  :global(.si-meta) {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    padding-top: 1px;
  }

  :global(.si-tier) {
    font-family: var(--font-ui);
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-teal);
    opacity: 0.75;
    white-space: nowrap;
  }

  :global(.si-date) {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    color: #9CA3AF;
    white-space: nowrap;
  }

  :global(mark) {
    background: rgba(91, 191, 181, 0.3);
    color: inherit;
    border-radius: 2px;
    padding: 0 1px;
  }

  /* ── Tier section headers ── */
  :global(.tier-section) {
    border-top: 1px solid var(--color-border);
    margin-top: 0.25rem;
  }

  :global(.tier-toggle) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.4rem 1.25rem;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-muted);
    text-align: left;
    transition: color 0.12s;
  }

  :global(.tier-toggle:hover) { color: var(--color-heading); }

  :global(.tier-toggle-chevron::before) {
    content: '▶';
    font-size: 0.5rem;
    display: inline-block;
    transition: transform 0.15s;
  }

  :global(.tier-section[data-open="true"] .tier-toggle-chevron::before) {
    content: '▼';
  }

  :global(.tier-toggle-count) {
    margin-left: auto;
    font-weight: 400;
    opacity: 0.6;
  }

  :global(.is-hidden) { display: none; }

  /* ── Footer ── */
  .search-footer {
    flex-shrink: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 1rem;
    background: var(--color-surface);
  }

  .search-status {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    color: var(--color-muted);
  }

  .search-keys {
    display: none;
    font-family: var(--font-ui);
    font-size: 0.65rem;
    color: var(--color-muted);
    gap: 0.25rem;
    align-items: center;
  }

  @media (min-width: 500px) { .search-keys { display: flex; } }

  .search-keys kbd {
    display: inline-block;
    font-family: inherit;
    font-size: 0.62rem;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 1px 5px;
    background: var(--color-bg);
    color: var(--color-muted);
  }

  /* ── Tag cloud (idle state) ── */
  .search-idle-cloud {
    padding: 0.75rem 1rem 0.6rem;
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .search-idle-label {
    font-family: var(--font-ui);
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-bottom: 0.5rem;
  }

  .search-idle-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .search-idle-tag {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-navy);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.18em 0.6em;
    text-decoration: none;
    transition: background 0.12s, border-color 0.12s;
  }

  .search-idle-tag:hover {
    background: var(--color-border);
    border-color: var(--color-navy);
  }
</style>
