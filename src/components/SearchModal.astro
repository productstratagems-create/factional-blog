---
import { getCollection } from 'astro:content';
import { articleHref } from '../utils/slug';

const articles = await getCollection('articles', ({ data }) => !data.draft);
const searchIndex = articles
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map(entry => ({
    title: entry.data.title,
    href: articleHref(entry.id),
    category: entry.data.category,
    excerpt: (entry.data.excerpt ?? '').slice(0, 160),
    lang: entry.data.lang ?? 'no',
  }));
---

<dialog class="search-dialog" id="search-dialog" aria-label="Søk i artikler">
  <div class="search-panel">

    <!-- Input row -->
    <div class="search-input-row">
      <svg class="search-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor"
           stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
        <circle cx="8.5" cy="8.5" r="5.25"/>
        <line x1="12.5" y1="12.5" x2="17" y2="17"/>
      </svg>
      <input
        id="search-input"
        type="search"
        class="search-input"
        placeholder="Søk i artikler…"
        autocomplete="off"
        spellcheck="false"
        aria-label="Søk"
        aria-autocomplete="list"
        aria-controls="search-listbox"
        aria-haspopup="listbox"
      />
      <button class="search-close-btn" id="search-close" aria-label="Lukk søk">
        <kbd>Esc</kbd>
      </button>
    </div>

    <!-- Results -->
    <ul class="search-listbox" id="search-listbox" role="listbox" aria-label="Søkeresultater"></ul>

    <!-- Footer -->
    <div class="search-footer">
      <span class="search-status" id="search-status" aria-live="polite">
        Søk blant {searchIndex.length} artikler
      </span>
      <span class="search-keys" aria-hidden="true">
        <kbd>↑</kbd><kbd>↓</kbd> naviger &ensp;
        <kbd>↵</kbd> åpne &ensp;
        <kbd>Esc</kbd> lukk
      </span>
    </div>

  </div>
</dialog>

<script define:vars={{ searchIndex }}>
  const dialog  = document.getElementById('search-dialog');
  const input   = document.getElementById('search-input');
  const listbox = document.getElementById('search-listbox');
  const status  = document.getElementById('search-status');
  const closeBtn = document.getElementById('search-close');

  let activeIdx   = -1;
  let lastTrigger = null;
  let debounce    = null;

  // ── Open / Close ──────────────────────────────────────────────

  function openSearch(trigger = null) {
    lastTrigger = trigger;
    input.value = '';
    renderEmpty();
    activeIdx = -1;
    dialog.showModal();
    requestAnimationFrame(() => input.focus());
  }

  function closeSearch() {
    dialog.close();
    lastTrigger?.focus();
  }

  // Backdrop click (click lands on <dialog> itself, not .search-panel)
  dialog.addEventListener('click', e => { if (e.target === dialog) closeSearch(); });

  // Native Escape via dialog 'cancel'
  dialog.addEventListener('cancel', e => { e.preventDefault(); closeSearch(); });

  closeBtn.addEventListener('click', closeSearch);

  // Wire up all header search buttons
  document.querySelectorAll('.search-btn').forEach(btn => {
    btn.addEventListener('click', () => openSearch(btn));
  });

  // Global keyboard shortcut
  document.addEventListener('keydown', e => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      dialog.open ? closeSearch() : openSearch();
    }
  });

  // ── Input with debounce ───────────────────────────────────────

  input.addEventListener('input', () => {
    clearTimeout(debounce);
    debounce = setTimeout(() => {
      activeIdx = -1;
      renderResults(input.value);
    }, 80);
  });

  // ── Arrow-key / Enter navigation ─────────────────────────────

  input.addEventListener('keydown', e => {
    const items = listbox.querySelectorAll('[role="option"]');
    if (!items.length) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      setActive(Math.min(activeIdx + 1, items.length - 1), items);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      const next = activeIdx - 1;
      if (next < 0) {
        // Return focus to input, deselect all
        setActive(-1, items);
      } else {
        setActive(next, items);
      }
    } else if (e.key === 'Enter') {
      e.preventDefault();
      if (activeIdx >= 0) {
        items[activeIdx]?.querySelector('a')?.click();
      } else if (items.length > 0) {
        // Enter with no selection → go to first result
        items[0]?.querySelector('a')?.click();
      }
    }
  });

  function setActive(idx, items) {
    items.forEach((el, i) => {
      const selected = i === idx;
      el.setAttribute('aria-selected', selected ? 'true' : 'false');
      el.classList.toggle('is-active', selected);
    });
    activeIdx = idx;

    if (idx >= 0) {
      input.setAttribute('aria-activedescendant', items[idx].id);
      items[idx].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    } else {
      input.removeAttribute('aria-activedescendant');
    }
  }

  // ── Render ────────────────────────────────────────────────────

  function escRe(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

  function highlight(text, q) {
    if (!q) return text;
    return text.replace(new RegExp(`(${escRe(q)})`, 'gi'), '<mark>$1</mark>');
  }

  function renderEmpty() {
    listbox.innerHTML = '';
    status.textContent = `Søk blant ${searchIndex.length} artikler`;
    input.removeAttribute('aria-activedescendant');
  }

  function renderResults(query) {
    const q  = query.trim();
    const ql = q.toLowerCase();

    if (!q) { renderEmpty(); return; }

    const matches = searchIndex.filter(a =>
      a.title.toLowerCase().includes(ql) || a.excerpt.toLowerCase().includes(ql)
    );

    const total = matches.length;
    status.textContent = total
      ? `${total} resultat${total === 1 ? '' : 'er'}`
      : `Ingen resultater for «${q}»`;

    if (!total) {
      listbox.innerHTML = `
        <li class="no-results">
          Ingen artikler matcher <strong>«${q}»</strong>
        </li>`;
      return;
    }

    listbox.innerHTML = matches.slice(0, 12).map((a, i) => `
      <li id="search-result-${i}" role="option" aria-selected="false" class="search-item">
        <a href="${a.href}" class="search-item-link">
          <span class="si-meta">
            <span class="si-category">${a.category}</span>
            <span class="si-lang">${a.lang.toUpperCase()}</span>
          </span>
          <span class="si-title">${highlight(a.title, q)}</span>
          <span class="si-excerpt">${highlight(a.excerpt, q)}</span>
        </a>
      </li>
    `).join('');

    listbox.querySelectorAll('a').forEach(a => a.addEventListener('click', closeSearch));
  }
</script>

<style>
  /* Native <dialog> resets */
  .search-dialog {
    padding: 0;
    border: none;
    border-radius: var(--radius-md);
    background: transparent;
    overflow: visible;
    width: min(640px, 94vw);
    max-height: 85vh;
    /* Position near top */
    margin-top: 10vh;
    margin-inline: auto;
    /* Slide-in animation */
    opacity: 0;
    transform: translateY(-12px) scale(0.98);
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  .search-dialog[open] {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .search-dialog::backdrop {
    background: rgba(10, 3, 3, 0.5);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
  }

  /* ── Panel ── */
  .search-panel {
    background: var(--color-bg);
    border-radius: var(--radius-md);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.28), 0 0 0 1px rgba(0,0,0,0.06);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: 85vh;
  }

  /* ── Input row ── */
  .search-input-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .search-icon {
    width: 18px;
    height: 18px;
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    border: none;
    outline: none;
    font-family: var(--font-ui);
    font-size: 1rem;
    color: var(--color-text);
    background: transparent;
    min-width: 0;
    caret-color: var(--color-teal);
  }

  .search-input::placeholder { color: var(--color-muted); }
  .search-input::-webkit-search-cancel-button { display: none; }

  .search-close-btn {
    flex-shrink: 0;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    border-radius: 5px;
    cursor: pointer;
    padding: 2px 8px;
    transition: background 0.15s;
  }

  .search-close-btn:hover { background: var(--color-border); }

  .search-close-btn kbd {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-muted);
    pointer-events: none;
  }

  /* ── Results listbox ── */
  .search-listbox {
    list-style: none;
    margin: 0;
    padding: 0.35rem 0;
    overflow-y: auto;
    flex: 1;
    scroll-padding-block: 0.35rem;
  }

  .no-results {
    padding: 1.25rem 1.25rem;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .no-results strong { color: var(--color-heading); font-weight: 600; }

  /* ── Individual result ── */
  .search-item { display: block; }

  .search-item-link {
    display: grid;
    grid-template-rows: auto auto auto;
    gap: 1px;
    padding: 0.6rem 1.25rem;
    text-decoration: none;
    transition: background 0.1s;
    cursor: pointer;
  }

  .search-item-link:hover,
  .search-item.is-active .search-item-link {
    background: var(--color-surface);
  }

  /* Left border accent on active item */
  .search-item.is-active .search-item-link {
    border-left: 2px solid var(--color-teal);
    padding-left: calc(1.25rem - 2px);
  }

  .si-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1px;
  }

  .si-category {
    font-family: var(--font-ui);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-teal);
  }

  .si-lang {
    font-family: var(--font-ui);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 0 4px;
    line-height: 1.6;
  }

  .si-title {
    font-family: var(--font-display);
    font-size: 0.88rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-heading);
    line-height: 1.2;
    display: block;
  }

  .si-excerpt {
    font-family: var(--font-body);
    font-size: 0.78rem;
    line-height: 1.4;
    color: var(--color-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
  }

  /* Highlight */
  .search-item-link :global(mark) {
    background: rgba(91, 191, 181, 0.28);
    color: inherit;
    border-radius: 2px;
    padding: 0 1px;
  }

  /* ── Footer ── */
  .search-footer {
    flex-shrink: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 1.25rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .search-status {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    color: var(--color-muted);
  }

  .search-keys {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    color: var(--color-muted);
    display: none;
  }

  @media (min-width: 500px) { .search-keys { display: inline; } }

  .search-keys kbd {
    display: inline-block;
    font-family: inherit;
    font-size: 0.65rem;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 1px 5px;
    background: var(--color-bg);
    color: var(--color-muted);
  }
</style>
