---
import ArticleCard from './ArticleCard.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { articleHref } from '../utils/slug';
import { SERIES } from '../data/series';

interface Props {
  articles: CollectionEntry<'articles'>[];
  columns?: 2 | 3;
  id?: string;
}

const { articles, columns = 3, id } = Astro.props;

const allArticles = await getCollection('articles', e => !e.data.draft);
const seriesMap = new Map<string, string[]>();
for (const a of allArticles.sort((a, b) => a.data.date.getTime() - b.data.date.getTime())) {
  if (a.data.series) {
    if (!seriesMap.has(a.data.series)) seriesMap.set(a.data.series, []);
    seriesMap.get(a.data.series)!.push(a.id);
  }
}
---

{articles.length === 0 ? (
  <p class="no-articles">Ingen artikler funnet.</p>
) : (
  <div class:list={['article-grid', `article-grid--${columns}col`]} id={id}>
    {articles.map((article) => {
      const wordCount = article.body?.split(/\s+/).length ?? 0;
      const readingTime = article.data.readingTimeMinutes ?? Math.max(1, Math.ceil(wordCount / 200));

      const s = article.data.series;
      const seriesIds = s ? seriesMap.get(s) : undefined;
      const seriesPosition = seriesIds
        ? { title: SERIES[s!]?.title ?? s!, part: seriesIds.indexOf(article.id) + 1, total: seriesIds.length }
        : undefined;

      return (
        <ArticleCard
          title={article.data.title}
          excerpt={article.data.excerpt}
          href={articleHref(article.id)}
          heroImage={article.data.heroImage}
          heroImageAlt={article.data.heroImageAlt}
          category={article.data.category}
          pubDate={article.data.date}
          author={article.data.author}
          readingTime={readingTime}
          lang={article.data.lang}
          featured={article.data.featured}
          tags={article.data.tags}
          seriesPosition={seriesPosition}
        />
      );
    })}
  </div>
)}

<style>
  .article-grid {
    display: grid;
    gap: var(--spacing-xl);
  }

  .article-grid--2col {
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 28rem), 1fr));
  }

  .article-grid--3col {
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
  }

  .no-articles {
    font-family: var(--font-ui);
    color: var(--color-muted);
    text-align: center;
    padding: var(--spacing-3xl) 0;
  }
</style>
